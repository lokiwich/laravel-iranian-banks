{
    "name": "lokiwich/laravel-iranian-banks",
    "description": "Iranian Shetab banks for Laravel — names, SVG icons, card BIN prefixes, and bank detection from card numbers.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "iran",
        "banks",
        "shetab",
        "card",
        "bin",
        "iban"
    ],
    "authors": [
        {
            "name": "Lokiwich",
            "email": "aligolkarali@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Lokiwich\\IranianBanks\\": "src/",
            "Lokiwich\\IranianBanks\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lokiwich\\IranianBanks\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lokiwich\\IranianBanks\\IranianBanksServiceProvider"
            ],
            "aliases": {
                "IranianBanks": "Lokiwich\\IranianBanks\\Facades\\IranianBanks"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
